<?xml version="1.0" encoding="UTF-8"?>

<web-app xmlns="https://jakarta.ee/xml/ns/jakartaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee
         https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd"
         version="6.0">

  <!-- ========================================= -->
  <!-- APPLICATION NAME -->
  <!-- ========================================= -->

  <display-name>Smart Task Management System</display-name>

  <!-- ========================================= -->
  <!-- WELCOME PAGE -->
  <!-- ========================================= -->

  <welcome-file-list>
    <welcome-file>index.jsp</welcome-file>
  </welcome-file-list>

  <!-- ========================================= -->
  <!-- SESSION CONFIGURATION -->
  <!-- ========================================= -->

  <session-config>
    <session-timeout>30</session-timeout>
  </session-config>

  <!-- ========================================= -->
  <!-- ERROR PAGES -->
  <!-- ========================================= -->

  <error-page>
    <error-code>404</error-code>
    <location>/error/404.jsp</location>
  </error-page>

  <error-page>
    <error-code>500</error-code>
    <location>/error/500.jsp</location>
  </error-page>

  <!-- ========================================= -->
  <!-- LOGIN SERVLET -->
  <!-- ========================================= -->

  <servlet>
    <servlet-name>LoginServlet</servlet-name>
    <servlet-class>controller.LoginServlet</servlet-class>
  </servlet>

  <servlet-mapping>
    <servlet-name>LoginServlet</servlet-name>
    <url-pattern>/login</url-pattern>
  </servlet-mapping>

  <!-- ========================================= -->
  <!-- REGISTER SERVLET -->
  <!-- ========================================= -->

  <servlet>
    <servlet-name>RegisterServlet</servlet-name>
    <servlet-class>controller.RegisterServlet</servlet-class>
  </servlet>

  <servlet-mapping>
    <servlet-name>RegisterServlet</servlet-name>
    <url-pattern>/register</url-pattern>
  </servlet-mapping>

  <!-- ========================================= -->
  <!-- LOGOUT SERVLET -->
  <!-- ========================================= -->

  <servlet>
    <servlet-name>LogoutServlet</servlet-name>
    <servlet-class>controller.LogoutServlet</servlet-class>
  </servlet>

  <servlet-mapping>
    <servlet-name>LogoutServlet</servlet-name>
    <url-pattern>/logout</url-pattern>
  </servlet-mapping>

  <!-- ========================================= -->
  <!-- DASHBOARD SERVLET -->
  <!-- ========================================= -->

  <servlet>
    <servlet-name>DashboardServlet</servlet-name>
    <servlet-class>controller.DashboardServlet</servlet-class>
  </servlet>

  <servlet-mapping>
    <servlet-name>DashboardServlet</servlet-name>
    <url-pattern>/dashboard</url-pattern>
  </servlet-mapping>

  <!-- ========================================= -->
  <!-- ADD TASK SERVLET -->
  <!-- ========================================= -->

  <servlet>
    <servlet-name>AddTaskServlet</servlet-name>
    <servlet-class>controller.AddTaskServlet</servlet-class>
  </servlet>

  <servlet-mapping>
    <servlet-name>AddTaskServlet</servlet-name>
    <url-pattern>/addTask</url-pattern>
  </servlet-mapping>

  <!-- ========================================= -->
  <!-- UPDATE TASK SERVLET -->
  <!-- ========================================= -->

  <servlet>
    <servlet-name>UpdateTaskServlet</servlet-name>
    <servlet-class>controller.UpdateTaskServlet</servlet-class>
  </servlet>

  <servlet-mapping>
    <servlet-name>UpdateTaskServlet</servlet-name>
    <url-pattern>/updateTask</url-pattern>
  </servlet-mapping>

  <!-- ========================================= -->
  <!-- DELETE TASK SERVLET -->
  <!-- ========================================= -->

  <servlet>
    <servlet-name>DeleteTaskServlet</servlet-name>
    <servlet-class>controller.DeleteTaskServlet</servlet-class>
  </servlet>

  <servlet-mapping>
    <servlet-name>DeleteTaskServlet</servlet-name>
    <url-pattern>/deleteTask</url-pattern>
  </servlet-mapping>

  <!-- ========================================= -->
  <!-- TASK SERVLET -->
  <!-- ========================================= -->

  <servlet>
    <servlet-name>TaskServlet</servlet-name>
    <servlet-class>controller.TaskServlet</servlet-class>
  </servlet>

  <servlet-mapping>
    <servlet-name>TaskServlet</servlet-name>
    <url-pattern>/task</url-pattern>
  </servlet-mapping>

  <!-- ========================================= -->
  <!-- SEARCH TASK SERVLET -->
  <!-- ========================================= -->

  <servlet>
    <servlet-name>SearchTaskServlet</servlet-name>
    <servlet-class>controller.SearchTaskServlet</servlet-class>
  </servlet>

  <servlet-mapping>
    <servlet-name>SearchTaskServlet</servlet-name>
    <url-pattern>/searchTask</url-pattern>
  </servlet-mapping>

  <!-- ========================================= -->
  <!-- PROFILE SERVLET -->
  <!-- ========================================= -->

  <servlet>
    <servlet-name>ProfileServlet</servlet-name>
    <servlet-class>controller.ProfileServlet</servlet-class>
  </servlet>

  <servlet-mapping>
    <servlet-name>ProfileServlet</servlet-name>
    <url-pattern>/profile</url-pattern>
  </servlet-mapping>

  <!-- ========================================= -->
  <!-- FORGOT PASSWORD SERVLET -->
  <!-- ========================================= -->

  <servlet>
    <servlet-name>ForgotPasswordServlet</servlet-name>
    <servlet-class>controller.ForgotPasswordServlet</servlet-class>
  </servlet>

  <servlet-mapping>
    <servlet-name>ForgotPasswordServlet</servlet-name>
    <url-pattern>/forgotPassword</url-pattern>
  </servlet-mapping>

  <!-- ========================================= -->
  <!-- RESET PASSWORD SERVLET -->
  <!-- ========================================= -->

  <servlet>
    <servlet-name>ResetPasswordServlet</servlet-name>
    <servlet-class>controller.ResetPasswordServlet</servlet-class>
  </servlet>

  <servlet-mapping>
    <servlet-name>ResetPasswordServlet</servlet-name>
    <url-pattern>/resetPassword</url-pattern>
  </servlet-mapping>

  <!-- ========================================= -->
  <!-- CATEGORY SERVLET -->
  <!-- ========================================= -->

  <servlet>
    <servlet-name>CategoryServlet</servlet-name>
    <servlet-class>controller.CategoryServlet</servlet-class>
  </servlet>

  <servlet-mapping>
    <servlet-name>CategoryServlet</servlet-name>
    <url-pattern>/category</url-pattern>
  </servlet-mapping>

  <!-- ========================================= -->
  <!-- REMINDER SERVLET -->
  <!-- ========================================= -->

  <servlet>
    <servlet-name>ReminderServlet</servlet-name>
    <servlet-class>controller.ReminderServlet</servlet-class>
  </servlet>

  <servlet-mapping>
    <servlet-name>ReminderServlet</servlet-name>
    <url-pattern>/reminder</url-pattern>
  </servlet-mapping>

  <!-- ========================================= -->
  <!-- DOWNLOAD TASK REPORT SERVLET -->
  <!-- ========================================= -->

  <servlet>
    <servlet-name>DownloadTaskReportServlet</servlet-name>
    <servlet-class>controller.DownloadTaskReportServlet</servlet-class>
  </servlet>

  <servlet-mapping>
    <servlet-name>DownloadTaskReportServlet</servlet-name>
    <url-pattern>/downloadTaskReport</url-pattern>
  </servlet-mapping>

  <!-- ========================================= -->
  <!-- AUTH FILTER -->
  <!-- ========================================= -->

  <filter>
    <filter-name>AuthFilter</filter-name>
    <filter-class>filter.AuthFilter</filter-class>
  </filter>

  <filter-mapping>
    <filter-name>AuthFilter</filter-name>
    <url-pattern>/dashboard/*</url-pattern>
  </filter-mapping>

  <filter-mapping>
    <filter-name>AuthFilter</filter-name>
    <url-pattern>/task</url-pattern>
  </filter-mapping>

  <filter-mapping>
    <filter-name>AuthFilter</filter-name>
    <url-pattern>/task/*</url-pattern>
  </filter-mapping>

  <filter-mapping>
    <filter-name>AuthFilter</filter-name>
    <url-pattern>/profile/*</url-pattern>
  </filter-mapping>

</web-app>
